# ==== Sunucu ====
PORT=4000
# Frontend'in çalıştığı adres(ler) — virgülle ayırarak birden fazla origin girilebilir
CORS_ORIGIN=http://localhost:5173

# ==== Veritabanı (PostgreSQL) ====
# Örnek: postgresql://KULLANICI:SIFRE@localhost:5432/yakamoz?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yakamoz?schema=public"

# ==== JWT ====
JWT_SECRET="lutfen-bu-degeri-guclu-rastgele-bir-deger-ile-degistirin"
JWT_EXPIRES_IN="8h"

# ==== Varsayılan Admin (yalnızca ilk `npm run seed` çalıştığında kullanılır) ====
# Not: Bu bilgiler yalnızca geliştirme/kurulum amaçlıdır. İlk girişten sonra
# admin panelinden şifre değiştirilmesi şiddetle önerilir.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=yakamoz2026
